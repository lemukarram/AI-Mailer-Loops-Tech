# aiMailSaas Environment Configuration

# --- Database Settings ---
# For Docker: Use 'db' as DB_HOST
# For Local/Shared Hosting: Use 'localhost' or your host's DB IP
DB_HOST=localhost
DB_NAME=aimailsaas
DB_USER=root
DB_PASS=root_password

# --- Security Settings ---
# This key is required to run migrations: /migrate.php?key=YOUR_ADMIN_KEY
# Change this to a long random string for production
ADMIN_KEY=SECURE_ADMIN_KEY

# --- App Settings ---
# The base URL of your application (trailing slash included)
APP_URL=http://localhost:8080/

# --- Note for Non-Docker Deployment ---
# 1. Rename this file to .env
# 2. Ensure your PHP version is 8.1 or higher
# 3. Enable mysqli, pdo_mysql, and curl extensions in your php.ini
